SALES_ENABLED=false
NEXT_PUBLIC_SALES_ENABLED=false
CRYPTO_CHECKOUT_ENABLED=false
NEXT_PUBLIC_CRYPTO_CHECKOUT_ENABLED=false
DATABASE_URL=
SITE_PUBLIC_URL=https://markshnaknaks.com
NEXT_PUBLIC_SITE_URL=https://markshnaknaks.com

# Stripe Payment Links are public checkout URLs, but keep live links out of the
# source tree until launch so accidental purchases are not discoverable in Git.
STRIPE_PAYMENT_LINK_COSPLAY_STARTER_PACK=
STRIPE_PRODUCT_ID_COSPLAY_STARTER_PACK=
STRIPE_PRICE_ID_COSPLAY_STARTER_PACK=
STRIPE_PAYMENT_LINK_ID_COSPLAY_STARTER_PACK=

STRIPE_PAYMENT_LINK_SOFT_CATBOY_DROP=
STRIPE_PRODUCT_ID_SOFT_CATBOY_DROP=
STRIPE_PRICE_ID_SOFT_CATBOY_DROP=
STRIPE_PAYMENT_LINK_ID_SOFT_CATBOY_DROP=

STRIPE_PAYMENT_LINK_BEHIND_THE_SCENES=
STRIPE_PRODUCT_ID_BEHIND_THE_SCENES=
STRIPE_PRICE_ID_BEHIND_THE_SCENES=
STRIPE_PAYMENT_LINK_ID_BEHIND_THE_SCENES=

STRIPE_PAYMENT_LINK_VIP_BUNDLE=
STRIPE_PRODUCT_ID_VIP_BUNDLE=
STRIPE_PRICE_ID_VIP_BUNDLE=
STRIPE_PAYMENT_LINK_ID_VIP_BUNDLE=
STRIPE_WEBHOOK_SECRET=

BTCPAY_SERVER_URL=https://pay.markshnaknaks.com
BTCPAY_STORE_ID=
BTCPAY_API_KEY=
BTCPAY_WEBHOOK_SECRET=
BTCPAY_BTC_WALLET_READY=false
NEXT_PUBLIC_BTCPAY_BTC_WALLET_READY=false
BTCPAY_LTC_ENABLED=false
NEXT_PUBLIC_BTCPAY_LTC_ENABLED=false

# Stablecoins are intentionally separate from BTCPay BTC checkout. Use
# solana-pay for a free self-hosted USDC flow, or shkeeper/bitcart after the
# provider is deployed and webhook-tested.
STABLECOIN_PROVIDER=none
STABLECOIN_RAIL_READY=false
NEXT_PUBLIC_STABLECOIN_RAIL_READY=false
STABLECOIN_PROCESSOR_URL=
STABLECOIN_CHECKOUT_URL=
STABLECOIN_API_KEY=
SHKEEPER_API_KEY=
STABLECOIN_WEBHOOK_SECRET=
STABLECOIN_FIAT=USD
STABLECOIN_EUR_TO_USD_RATE=
STABLECOIN_EUR_TO_USD_RATE_SOURCE=frankfurter
STABLECOIN_RATE_FETCH_TIMEOUT_MS=3000
STABLECOIN_DEFAULT_RAIL=usdc-solana
STABLECOIN_USDC_SOLANA_ENABLED=false
NEXT_PUBLIC_STABLECOIN_USDC_SOLANA_ENABLED=false
STABLECOIN_USDC_POLYGON_ENABLED=false
STABLECOIN_USDT_TRON_ENABLED=false
SHKEEPER_USDC_SOLANA_CRYPTO_NAME=USDC
SHKEEPER_USDC_POLYGON_CRYPTO_NAME=POLYGON-USDC
SHKEEPER_USDT_TRON_CRYPTO_NAME=USDT

SOLANA_PAY_ENABLED=false
NEXT_PUBLIC_SOLANA_PAY_ENABLED=false
SOLANA_PAY_RPC_URL=https://api.mainnet-beta.solana.com
# Optional comma-separated read-only fallback RPCs. No private key is used here.
SOLANA_PAY_RPC_URLS=https://api.mainnet-beta.solana.com,https://solana-rpc.publicnode.com
SOLANA_PAY_INVOICE_TTL_MINUTES=30
SOLANA_PAY_VERIFY_TIMEOUT_MS=8000
SOLANA_PAY_RECIPIENT=
SOLANA_PAY_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Private delivery storage. Keep the bucket private; downloads are served via
# short-lived signed R2 URLs generated by the server.
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_BUCKET_PRIVATE=marky-private-packs
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_SIGNED_URL_TTL_SECONDS=300
DELIVERY_TOKEN_TTL_DAYS=7

# Optional protected accounting export endpoint:
# GET /api/admin/orders/export with Authorization: Bearer <ADMIN_API_TOKEN>
ADMIN_API_TOKEN=

# Optional Cloudflare Access origin verification for /api/admin/*.
# Recommended production setup: protect https://markshnaknaks.com/admin* in
# Cloudflare Zero Trust, then set these values so the origin also validates the
# Access JWT forwarded in Cf-Access-Jwt-Assertion.
CLOUDFLARE_ACCESS_AUD=
CLOUDFLARE_ACCESS_TEAM_DOMAIN=
CLOUDFLARE_ACCESS_JWKS_URL=
CLOUDFLARE_ACCESS_ISSUER=
CLOUDFLARE_ACCESS_ALLOWED_EMAILS=

# Telegram bot integration. TELEGRAM_ADMIN_CHAT_ID is optional and should be a
# trusted chat/channel id where paid order delivery links may be sent.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=markshnaknaksbot
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_VIP_CHAT_ID=

# Optional Cloudflare Turnstile anti-spam for /api/contact.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_REQUIRED=false
NEXT_PUBLIC_TURNSTILE_REQUIRED=false

# Optional legal disclosure. Public checkout is not gated by these variables.
# Use an actually contracted/referenceable mediator if one is added later; do not invent values.
CONSUMER_MEDIATOR_NAME=
CONSUMER_MEDIATOR_ADDRESS=
CONSUMER_MEDIATOR_WEBSITE=
